{
    "manifest_version": 3,
    "name": "Unfollowers InstaBot",
    "version": "1.0",
    "description": "Extracts 'followers' and 'following' to find 'unfollowers'.",
    "icons": {
        "16": "icon.png",
        "32": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "downloads"
    ],
    "action": {
        "default_popup": "extract_unfollowers_popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.instagram.com/*"
            ],
            "js": [
                "constants.js",
                "extract_unfollowers.js"
            ]
        }
    ]
}